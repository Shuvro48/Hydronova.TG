# ─── Supabase (free tier) — auth + database ──────────────────────────────────
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key...

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── FloodGPT (optional) ──────────────────────────────────────────────────────
# Without this key, FloodGPT still works using smart built-in fallback responses.
# Get a free-credit key at https://console.anthropic.com if you want live AI answers.
ANTHROPIC_API_KEY=sk-ant-...your-key...
